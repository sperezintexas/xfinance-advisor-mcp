# Copy to .env (never commit real keys)
RENTAL_AI_KEY=atxr_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RENTAL_AI_BASE_URL=https://atx.fintech-advisor.ai

# Optional but recommended for any public deployment.
# When set, Grok (or any caller) must send: Authorization: Bearer <this-token>
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# Port (Railway, Fly, Render etc. usually inject PORT automatically)
PORT=3000
