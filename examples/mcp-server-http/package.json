{
  "name": "rental-ai-mcp-server-http",
  "version": "0.1.0",
  "type": "module",
  "description": "Remote HTTP/SSE MCP server for the aTx Finance Rental AI (white-label). Deploy this to get a public URL you can register in Grok Business Apps or at grok.com/connectors.",
